    <!-- CTA -->
    <div class="cta-banner anim d10">
        <div class="cta-title"><span class="en">ESPORTS PROGRAMS FOR <span style="color:var(--gold)">SCHOOLS</span></span><span class="es">PROGRAMAS DE ESPORTS PARA <span style="color:var(--gold)">ESCUELAS</span></span></div>
        <p class="cta-desc">
