    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-brand"><span class="gold">LA VOZ</span> ESPORTS TRAINING</div>
        <div class="footer-sub"><span class="en">Powered by Ritnome™ · GoStar Digital LLC · Puerto Rico</span><span class="es">Impulsado por Ritnome™ · GoStar Digital LLC · Puerto Rico</span></div>
        <div class="footer-links">
            <a href="https://lavozpr.com/esports.html">La Voz Esports</a>
